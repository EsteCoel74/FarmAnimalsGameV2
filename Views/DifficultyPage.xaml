<UserControl x:Class="FarmAnimalsGameV2.Views.DifficultyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FarmAnimalsGameV2.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Farm.png" Stretch="UniformToFill" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="240">
            <Button Content="Facile" Background="#FF7FB2FF" Foreground="White" Height="48" FontSize="18" Margin="0,0,0,16" Click="EasyButton_Click" />
            <Button Content="Moyen" Background="#FF84D37E" Foreground="White" Height="48" FontSize="18" Margin="0,0,0,16" Click="MediumButton_Click" />
            <Button Content="Difficile" Background="#FFFFB74D" Foreground="White" Height="48" FontSize="18" Margin="0,0,0,16" Click="HardButton_Click" />
            <Button Content="Retour" Background="#FFB0BEC5" Foreground="White" Height="44" FontSize="16" Click="BackButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
