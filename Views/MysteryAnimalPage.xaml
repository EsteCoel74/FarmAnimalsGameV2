<UserControl x:Class="FarmAnimalsGameV2.Views.MysteryAnimalPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#1A1A2E">

    <UserControl.Resources>

        <!-- Bouton réponse -->
        <Style x:Key="AnswerBtn" TargetType="Button">
            <Setter Property="Background"       Value="#16213E"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="16"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="BorderBrush"      Value="#2A3F6F"/>
            <Setter Property="BorderThickness"  Value="2"/>
            <Setter Property="Margin"           Value="8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="12,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#0F3460"/>
                                <Setter Property="BorderBrush" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton principal (Rejouer) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#E94560"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="24,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C73652"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cœur vie -->
        <Style x:Key="HeartStyle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="32"/>
            <Setter Property="Margin"           Value="5,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Vies (centre) -->
            <RowDefinition Height="*"/>
            <!-- Contenu jeu    -->
            <RowDefinition Height="Auto"/>
            <!-- Timer          -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar     -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════ -->
        <!-- ROW 0 — BARRE DE VIES                  -->
        <!-- ══════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="0,16,0,8" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="Heart1" Text="❤️" Style="{StaticResource HeartStyle}"/>
                <TextBlock x:Name="Heart2" Text="❤️" Style="{StaticResource HeartStyle}"/>
                <TextBlock x:Name="Heart3" Text="❤️" Style="{StaticResource HeartStyle}"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════ -->
        <!-- ROW 1 — ZONE DE JEU                    -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="24,0">

            <!-- ── Écran d'attente RFID ── -->
            <StackPanel x:Name="WaitingScreen"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🃏" FontSize="72" HorizontalAlignment="Center"/>
                <TextBlock Text="Approche ta carte animal !"
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Le lecteur RFID est prêt"
                           FontSize="14" Foreground="#888"
                           HorizontalAlignment="Center"/>

                <!-- Bouton démo (à retirer en prod) -->
                <Button Content="▶  Simuler une carte (démo)"
                        Style="{StaticResource PrimaryBtn}"
                        HorizontalAlignment="Center"
                        Margin="0,28,0,0"
                        Click="SimulateRfid_Click"/>
            </StackPanel>

            <!-- ── Écran de question ── -->
            <Grid x:Name="QuestionScreen" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Carte animal (gauche) -->
                <Border Grid.Column="0" Margin="0,0,12,0"
                        Background="#16213E" CornerRadius="16" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Badge RFID -->
                        <Border Background="#0F3460" CornerRadius="20" Padding="10,4"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <TextBlock x:Name="RfidBadge" Text="🏷 RFID : —"
                                       Foreground="#7EC8E3" FontSize="11"/>
                        </Border>

                        <!-- Emoji animal -->
                        <TextBlock x:Name="AnimalEmoji" Text="❓"
                                   FontSize="96" HorizontalAlignment="Center"/>

                        <!-- Indice -->
                        <TextBlock x:Name="AnimalHint"
                                   Text="" FontSize="13" Foreground="#AAA"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,14,0,0" MaxWidth="220"/>
                    </StackPanel>
                </Border>

                <!-- Réponses (droite) -->
                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Quel est cet animal ?"
                               FontSize="19" FontWeight="Bold" Foreground="White"
                               Margin="0,0,0,12"/>

                    <UniformGrid Grid.Row="1" x:Name="AnswerGrid" Rows="2" Columns="2">
                        <Button x:Name="BtnA" Style="{StaticResource AnswerBtn}"
                                Tag="0" Click="Answer_Click">
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnB" Style="{StaticResource AnswerBtn}"
                                Tag="1" Click="Answer_Click">
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnC" Style="{StaticResource AnswerBtn}"
                                Tag="2" Click="Answer_Click">
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnD" Style="{StaticResource AnswerBtn}"
                                Tag="3" Click="Answer_Click">
                            <TextBlock TextWrapping="Wrap" TextAlignment="Center"/>
                        </Button>
                    </UniformGrid>
                </Grid>
            </Grid>

            <!-- ── Écran Game Over ── -->
            <StackPanel x:Name="GameOverScreen" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="💀" FontSize="80" HorizontalAlignment="Center"/>
                <TextBlock Text="Game Over !"
                           FontSize="30" FontWeight="Bold" Foreground="#E94560"
                           HorizontalAlignment="Center" Margin="0,12,0,6"/>
                <TextBlock x:Name="GameOverScore"
                           FontSize="18" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>
                <Button Content="🔄  Rejouer"
                        Style="{StaticResource PrimaryBtn}"
                        HorizontalAlignment="Center"
                        Click="Replay_Click"/>
            </StackPanel>

            <!-- ── Écran Victoire ── -->
            <StackPanel x:Name="WinScreen" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🏆" FontSize="80" HorizontalAlignment="Center"/>
                <TextBlock Text="Bravo, tu as tout trouvé !"
                           FontSize="28" FontWeight="Bold" Foreground="#F5A623"
                           HorizontalAlignment="Center" Margin="0,12,0,6"/>
                <TextBlock x:Name="WinScore"
                           FontSize="18" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>
                <Button Content="🔄  Rejouer"
                        Style="{StaticResource PrimaryBtn}"
                        HorizontalAlignment="Center"
                        Click="Replay_Click"/>
            </StackPanel>

        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!-- ROW 2 — TIMER BAR                      -->
        <!-- ══════════════════════════════════════ -->
        <Border x:Name="TimerRow" Grid.Row="2"
                Padding="24,10" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⏱"
                           FontSize="18" Foreground="#888"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                <!-- Track -->
                <Border Grid.Column="1" Background="#16213E"
                        CornerRadius="5" Height="12" VerticalAlignment="Center">
                    <Border x:Name="TimerBar" Background="#27AE60"
                            CornerRadius="5" HorizontalAlignment="Left"
                            Width="500"/>
                </Border>

                <TextBlock Grid.Column="2" x:Name="TimerLabel"
                           Text="30s" FontSize="16" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════ -->
        <!-- ROW 3 — STATUS BAR                     -->
        <!-- ══════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#16213E" Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="En attente d'une carte RFID…"
                           Foreground="#888" FontSize="13"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Score : " Foreground="#888" FontSize="13"/>
                    <TextBlock x:Name="ScoreLabel"
                               Text="0" FontSize="15" FontWeight="Bold"
                               Foreground="#E94560"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
